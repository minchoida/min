<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Lenme Design System</title>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700&family=IBM+Plex+Sans:wght@300;400;500&family=IBM+Plex+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>

/* ============================================================
   LENME DESIGN SYSTEM — TOKENS
   ============================================================ */

:root {

  /* --- BRAND COLORS --- */
  --lenme-navy:       #0B1F3A;
  --lenme-navy-80:    #223350;
  --lenme-navy-60:    #3A4F6B;
  --lenme-navy-20:    #C8D2DE;
  --lenme-navy-10:    #E9EDF2;
  --lenme-navy-05:    #F4F6F9;

  --lenme-teal:       #00C896;
  --lenme-teal-80:    #33D3AB;
  --lenme-teal-40:    #99E9D5;
  --lenme-teal-15:    #D6F7EF;
  --lenme-teal-08:    #EDFCF8;

  --lenme-white:      #FFFFFF;
  --lenme-surface:    #F7F9FB;
  --lenme-surface2:   #EFF2F6;

  /* --- SEMANTIC / RISK COLORS --- */
  --risk-low:         #00C896;   /* green — safe */
  --risk-low-bg:      #EDFCF8;
  --risk-low-text:    #006B50;

  --risk-med:         #F5A623;   /* amber — moderate */
  --risk-med-bg:      #FEF6E7;
  --risk-med-text:    #7A4E00;

  --risk-high:        #E5383B;   /* red — high risk */
  --risk-high-bg:     #FDECEA;
  --risk-high-text:   #8B0000;

  --status-pending:   #6C8EBF;
  --status-pending-bg:#EEF3FA;

  --status-active:    #00C896;
  --status-active-bg: #EDFCF8;

  --status-completed: #6B7280;
  --status-completed-bg: #F3F4F6;

  --status-default:   #E5383B;
  --status-default-bg:#FDECEA;

  /* --- TYPOGRAPHY --- */
  --font-display: 'Syne', sans-serif;
  --font-body:    'IBM Plex Sans', sans-serif;
  --font-mono:    'IBM Plex Mono', monospace;

  --text-xs:   0.6875rem;  /* 11px */
  --text-sm:   0.8125rem;  /* 13px */
  --text-base: 0.9375rem;  /* 15px */
  --text-md:   1.0625rem;  /* 17px */
  --text-lg:   1.25rem;    /* 20px */
  --text-xl:   1.5rem;     /* 24px */
  --text-2xl:  2rem;       /* 32px */
  --text-3xl:  2.75rem;    /* 44px */

  /* --- SPACING (4pt base) --- */
  --space-1:  0.25rem;   /* 4px */
  --space-2:  0.5rem;    /* 8px */
  --space-3:  0.75rem;   /* 12px */
  --space-4:  1rem;      /* 16px */
  --space-5:  1.25rem;   /* 20px */
  --space-6:  1.5rem;    /* 24px */
  --space-8:  2rem;      /* 32px */
  --space-10: 2.5rem;    /* 40px */
  --space-12: 3rem;      /* 48px */
  --space-16: 4rem;      /* 64px */

  /* --- RADIUS --- */
  --radius-sm:   4px;
  --radius-md:   8px;
  --radius-lg:   12px;
  --radius-xl:   16px;
  --radius-2xl:  24px;
  --radius-full: 9999px;

  /* --- ELEVATION (shadows) --- */
  --shadow-sm:  0 1px 3px rgba(11,31,58,0.08);
  --shadow-md:  0 4px 12px rgba(11,31,58,0.10);
  --shadow-lg:  0 8px 24px rgba(11,31,58,0.12);

  /* --- BORDERS --- */
  --border-light:  1px solid rgba(11,31,58,0.08);
  --border-mid:    1px solid rgba(11,31,58,0.14);
  --border-strong: 1px solid rgba(11,31,58,0.24);
}

/* ============================================================
   PAGE SHELL
   ============================================================ */

* { box-sizing: border-box; margin: 0; padding: 0; }
html { scroll-behavior: smooth; }
body {
  background: #0F0F12;
  color: #E8EAF0;
  font-family: var(--font-body);
  font-size: var(--text-base);
  line-height: 1.6;
  -webkit-font-smoothing: antialiased;
}

/* ============================================================
   DOC LAYOUT
   ============================================================ */

.doc-wrap {
  display: grid;
  grid-template-columns: 220px 1fr;
  min-height: 100vh;
}

/* SIDEBAR */
.sidebar {
  position: fixed;
  top: 0; left: 0; bottom: 0;
  width: 220px;
  background: #17171C;
  border-right: 1px solid rgba(255,255,255,0.06);
  padding: 2rem 0;
  overflow-y: auto;
  z-index: 50;
}
.sidebar-logo {
  padding: 0 1.5rem 2rem;
  border-bottom: 1px solid rgba(255,255,255,0.06);
  margin-bottom: 1.5rem;
}
.sidebar-logo-name {
  font-family: var(--font-display);
  font-size: 1.1rem;
  font-weight: 700;
  color: #fff;
  letter-spacing: 0.04em;
}
.sidebar-logo-tag {
  font-family: var(--font-mono);
  font-size: 0.65rem;
  color: var(--lenme-teal);
  letter-spacing: 0.1em;
  text-transform: uppercase;
  margin-top: 2px;
}
.nav-group { margin-bottom: 1.5rem; padding: 0 1.5rem; }
.nav-group-label {
  font-family: var(--font-mono);
  font-size: 0.6rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.3);
  margin-bottom: 0.5rem;
}
.nav-link {
  display: block;
  font-size: 0.82rem;
  color: rgba(255,255,255,0.55);
  text-decoration: none;
  padding: 0.35rem 0;
  transition: color 0.15s;
}
.nav-link:hover { color: rgba(255,255,255,0.9); }
.nav-link.active { color: var(--lenme-teal); }

/* MAIN */
.main {
  margin-left: 220px;
  padding: 3rem 4rem;
  max-width: 1100px;
}

/* ============================================================
   SECTION HEADERS
   ============================================================ */

.section { margin-bottom: 5rem; }
.section-eyebrow {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.14em;
  text-transform: uppercase;
  color: var(--lenme-teal);
  margin-bottom: 0.75rem;
  display: flex; align-items: center; gap: 0.5rem;
}
.section-eyebrow::before {
  content: '';
  display: inline-block;
  width: 16px; height: 1px;
  background: var(--lenme-teal);
}
.section-title {
  font-family: var(--font-display);
  font-size: 1.8rem;
  font-weight: 700;
  color: #fff;
  margin-bottom: 0.5rem;
  letter-spacing: -0.01em;
}
.section-desc {
  font-size: 0.88rem;
  color: rgba(255,255,255,0.45);
  margin-bottom: 2.5rem;
  max-width: 560px;
  line-height: 1.7;
}

hr.divider {
  border: none;
  border-top: 1px solid rgba(255,255,255,0.06);
  margin: 3rem 0;
}

/* ============================================================
   TOKEN LABEL
   ============================================================ */

.token-label {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: rgba(255,255,255,0.3);
  display: block;
  margin-top: 0.35rem;
}
.token-value {
  font-family: var(--font-mono);
  font-size: 0.72rem;
  color: rgba(255,255,255,0.5);
}

/* ============================================================
   COLOR SWATCHES
   ============================================================ */

.swatch-group { margin-bottom: 2rem; }
.swatch-group-label {
  font-size: 0.75rem;
  font-weight: 500;
  color: rgba(255,255,255,0.4);
  margin-bottom: 0.75rem;
  text-transform: uppercase;
  letter-spacing: 0.08em;
  font-family: var(--font-mono);
}
.swatch-row {
  display: flex;
  gap: 0;
  border-radius: var(--radius-md);
  overflow: hidden;
  height: 60px;
  border: 1px solid rgba(255,255,255,0.06);
}
.swatch {
  flex: 1;
  display: flex;
  align-items: flex-end;
  padding: 0.3rem 0.4rem;
  cursor: default;
  position: relative;
  transition: flex 0.2s ease;
}
.swatch:hover { flex: 2; }
.swatch-hex {
  font-family: var(--font-mono);
  font-size: 0.58rem;
  opacity: 0;
  transition: opacity 0.15s;
  white-space: nowrap;
}
.swatch:hover .swatch-hex { opacity: 1; }

.swatch-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(100px, 1fr));
  gap: 1rem;
}
.swatch-card {
  border-radius: var(--radius-md);
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.06);
}
.swatch-color {
  height: 64px;
}
.swatch-info {
  background: #1E1E24;
  padding: 0.6rem 0.75rem;
}
.swatch-name {
  font-size: 0.72rem;
  font-weight: 500;
  color: rgba(255,255,255,0.8);
  display: block;
  margin-bottom: 2px;
}

/* ============================================================
   SEMANTIC COLOR PILLS
   ============================================================ */

.semantic-grid {
  display: grid;
  grid-template-columns: repeat(4, minmax(0,1fr));
  gap: 1rem;
  margin-bottom: 1.5rem;
}
.semantic-card {
  border-radius: var(--radius-lg);
  overflow: hidden;
  border: 1px solid rgba(255,255,255,0.06);
}
.semantic-top {
  height: 80px;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-mono); font-size: 0.72rem; font-weight: 500;
}
.semantic-bottom {
  background: #1E1E24;
  padding: 0.75rem;
}
.semantic-bottom .swatch-name { color: rgba(255,255,255,0.7); }

/* ============================================================
   TYPOGRAPHY SPECIMENS
   ============================================================ */

.type-specimen {
  background: #17171C;
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: var(--radius-lg);
  padding: 1.5rem 2rem;
  margin-bottom: 1rem;
  display: grid;
  grid-template-columns: 1fr auto;
  align-items: center;
  gap: 1rem;
}
.type-meta {
  text-align: right;
}
.type-meta .token-label { text-align: right; }
.type-scale-display {
  background: #17171C;
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: var(--radius-lg);
  padding: 2rem;
  margin-bottom: 2rem;
}
.type-scale-row {
  display: flex;
  align-items: baseline;
  gap: 1.5rem;
  padding: 1rem 0;
  border-bottom: 1px solid rgba(255,255,255,0.04);
}
.type-scale-row:last-child { border-bottom: none; }
.type-scale-meta {
  min-width: 180px;
  flex-shrink: 0;
}
.type-scale-meta .token-label { margin-top: 0; }
.type-sample { color: rgba(255,255,255,0.85); }
.type-sample.dimmed { color: rgba(255,255,255,0.4); }

/* ============================================================
   SPACING DISPLAY
   ============================================================ */

.spacing-grid {
  display: flex;
  flex-direction: column;
  gap: 0.5rem;
  background: #17171C;
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: var(--radius-lg);
  padding: 1.5rem;
}
.spacing-row {
  display: flex;
  align-items: center;
  gap: 1rem;
}
.spacing-bar-wrap {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 0.75rem;
}
.spacing-bar {
  height: 24px;
  background: linear-gradient(90deg, var(--lenme-teal) 0%, rgba(0,200,150,0.3) 100%);
  border-radius: 3px;
  flex-shrink: 0;
}
.spacing-meta {
  min-width: 80px;
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: rgba(255,255,255,0.4);
}
.spacing-token {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: var(--lenme-teal);
  min-width: 80px;
}
.spacing-px {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  color: rgba(255,255,255,0.3);
  min-width: 36px;
}

/* ============================================================
   RADIUS DISPLAY
   ============================================================ */

.radius-grid {
  display: grid;
  grid-template-columns: repeat(6, minmax(0,1fr));
  gap: 1rem;
}
.radius-card {
  background: #17171C;
  border: 1px solid rgba(255,255,255,0.06);
  border-radius: var(--radius-lg);
  padding: 1.25rem;
  text-align: center;
}
.radius-box {
  width: 48px; height: 48px;
  background: rgba(0,200,150,0.15);
  border: 1.5px solid var(--lenme-teal);
  margin: 0 auto 0.75rem;
}

/* ============================================================
   COMPONENT PREVIEW AREA
   ============================================================ */

.preview-surface {
  background: var(--lenme-surface);
  border-radius: var(--radius-xl);
  padding: 2rem;
  margin-bottom: 1rem;
  border: 1px solid rgba(11,31,58,0.1);
}
.component-label {
  font-family: var(--font-mono);
  font-size: 0.68rem;
  letter-spacing: 0.1em;
  text-transform: uppercase;
  color: rgba(255,255,255,0.3);
  margin-bottom: 0.75rem;
  margin-top: 1.5rem;
}
.component-label:first-child { margin-top: 0; }

/* ============================================================
   LENME COMPONENTS (light surface rendering)
   ============================================================ */

/* --- BUTTONS --- */
.btn {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  gap: 0.5rem;
  font-family: var(--font-body);
  font-weight: 500;
  border: none;
  cursor: pointer;
  transition: all 0.15s ease;
  white-space: nowrap;
  text-decoration: none;
  line-height: 1;
}
.btn:focus-visible {
  outline: 2px solid var(--lenme-teal);
  outline-offset: 2px;
}

/* Sizes */
.btn-sm  { font-size: 0.75rem; padding: 0.45rem 0.9rem; border-radius: var(--radius-sm); }
.btn-md  { font-size: 0.875rem; padding: 0.625rem 1.25rem; border-radius: var(--radius-md); }
.btn-lg  { font-size: 0.9375rem; padding: 0.875rem 1.75rem; border-radius: var(--radius-md); }
.btn-xl  { font-size: 1rem; padding: 1rem 2rem; border-radius: var(--radius-lg); letter-spacing: 0.01em; }

/* Variants */
.btn-primary {
  background: var(--lenme-navy);
  color: #fff;
  box-shadow: 0 2px 8px rgba(11,31,58,0.25);
}
.btn-primary:hover { background: var(--lenme-navy-80); transform: translateY(-1px); box-shadow: 0 4px 14px rgba(11,31,58,0.3); }
.btn-primary:active { transform: translateY(0); }

.btn-teal {
  background: var(--lenme-teal);
  color: var(--lenme-navy);
  font-weight: 600;
  box-shadow: 0 2px 8px rgba(0,200,150,0.3);
}
.btn-teal:hover { background: var(--lenme-teal-80); transform: translateY(-1px); box-shadow: 0 4px 14px rgba(0,200,150,0.35); }

.btn-outline {
  background: transparent;
  color: var(--lenme-navy);
  border: 1.5px solid var(--lenme-navy-20);
}
.btn-outline:hover { border-color: var(--lenme-navy); background: var(--lenme-navy-05); }

.btn-ghost {
  background: transparent;
  color: var(--lenme-navy-60);
}
.btn-ghost:hover { background: var(--lenme-navy-10); color: var(--lenme-navy); }

.btn-danger {
  background: var(--risk-high);
  color: #fff;
}
.btn-danger:hover { background: #c62b2e; transform: translateY(-1px); }

.btn-icon {
  width: 36px; height: 36px;
  padding: 0;
  border-radius: var(--radius-md);
  background: var(--lenme-navy-10);
  color: var(--lenme-navy-60);
  font-size: 0.9rem;
}
.btn-icon:hover { background: var(--lenme-navy-20); color: var(--lenme-navy); }

.btn:disabled {
  opacity: 0.4;
  cursor: not-allowed;
  transform: none !important;
}

/* --- STATUS BADGES --- */
.badge {
  display: inline-flex;
  align-items: center;
  gap: 0.3rem;
  font-family: var(--font-mono);
  font-size: 0.68rem;
  font-weight: 500;
  letter-spacing: 0.04em;
  padding: 0.25rem 0.65rem;
  border-radius: var(--radius-full);
}
.badge::before {
  content: '';
  width: 5px; height: 5px;
  border-radius: 50%;
  display: inline-block;
}
.badge-pending   { background: var(--status-pending-bg);   color: var(--status-pending);   }
.badge-pending::before { background: var(--status-pending); }
.badge-active    { background: var(--status-active-bg);    color: var(--risk-low-text);    }
.badge-active::before { background: var(--status-active); }
.badge-completed { background: var(--status-completed-bg); color: var(--status-completed); }
.badge-completed::before { background: var(--status-completed); }
.badge-default   { background: var(--status-default-bg);   color: var(--risk-high-text);   }
.badge-default::before { background: var(--status-default); }

/* --- RISK BADGES --- */
.risk-badge {
  display: inline-flex;
  align-items: center;
  gap: 0.35rem;
  font-size: 0.72rem;
  font-weight: 600;
  padding: 0.3rem 0.75rem;
  border-radius: var(--radius-full);
  font-family: var(--font-body);
}
.risk-low  { background: var(--risk-low-bg);  color: var(--risk-low-text);  }
.risk-med  { background: var(--risk-med-bg);  color: var(--risk-med-text);  }
.risk-high { background: var(--risk-high-bg); color: var(--risk-high-text); }

/* --- LENME SCORE INDICATOR --- */
.score-indicator {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  gap: 0.15rem;
}
.score-ring {
  width: 56px; height: 56px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-display);
  font-size: 1rem;
  font-weight: 700;
  border: 3px solid;
}
.score-ring.low  { border-color: var(--risk-low);  color: var(--risk-low-text);  background: var(--risk-low-bg); }
.score-ring.med  { border-color: var(--risk-med);  color: var(--risk-med-text);  background: var(--risk-med-bg); }
.score-ring.high { border-color: var(--risk-high); color: var(--risk-high-text); background: var(--risk-high-bg); }
.score-label {
  font-size: 0.65rem;
  font-weight: 500;
  text-transform: uppercase;
  letter-spacing: 0.06em;
}
.score-label.low  { color: var(--risk-low-text);  }
.score-label.med  { color: var(--risk-med-text);  }
.score-label.high { color: var(--risk-high-text); }

/* --- AVATAR (borrower color coding) --- */
.avatar {
  width: 40px; height: 40px;
  border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-family: var(--font-display);
  font-size: 0.9rem;
  font-weight: 700;
  flex-shrink: 0;
}
.avatar-green  { background: var(--risk-low-bg);  color: var(--risk-low-text);  }
.avatar-yellow { background: var(--risk-med-bg);  color: var(--risk-med-text);  }
.avatar-red    { background: var(--risk-high-bg); color: var(--risk-high-text); }

/* --- INPUT --- */
.input-wrap { position: relative; width: 100%; }
.input {
  width: 100%;
  background: #fff;
  border: 1.5px solid var(--lenme-navy-20);
  border-radius: var(--radius-md);
  font-family: var(--font-body);
  font-size: var(--text-sm);
  color: var(--lenme-navy);
  padding: 0.625rem 1rem;
  transition: border-color 0.15s, box-shadow 0.15s;
  outline: none;
}
.input:focus { border-color: var(--lenme-teal); box-shadow: 0 0 0 3px rgba(0,200,150,0.15); }
.input-label {
  font-size: 0.75rem;
  font-weight: 500;
  color: var(--lenme-navy-60);
  margin-bottom: 0.35rem;
  display: block;
}
.input-hint {
  font-size: 0.7rem;
  color: #6B7280;
  margin-top: 0.3rem;
}
.input-group { margin-bottom: 1rem; }

/* --- SLIDER --- */
.slider-wrap { display: flex; align-items: center; gap: 0.75rem; }
input[type=range].lenme-slider {
  -webkit-appearance: none;
  appearance: none;
  flex: 1;
  height: 4px;
  background: var(--lenme-navy-20);
  border-radius: var(--radius-full);
  outline: none;
  cursor: pointer;
}
input[type=range].lenme-slider::-webkit-slider-thumb {
  -webkit-appearance: none;
  appearance: none;
  width: 20px; height: 20px;
  border-radius: 50%;
  background: var(--lenme-navy);
  border: 3px solid #fff;
  box-shadow: 0 2px 6px rgba(11,31,58,0.25);
  cursor: pointer;
}
input[type=range].lenme-slider::-webkit-slider-runnable-track {
  height: 4px;
  border-radius: var(--radius-full);
}
.slider-value {
  font-family: var(--font-mono);
  font-size: 0.8rem;
  font-weight: 500;
  color: var(--lenme-navy);
  min-width: 48px;
  text-align: right;
}

/* --- LOAN CARD --- */
.loan-card {
  background: #fff;
  border: 1px solid rgba(11,31,58,0.08);
  border-radius: var(--radius-xl);
  padding: 1.25rem 1.5rem;
  box-shadow: var(--shadow-sm);
  transition: box-shadow 0.2s, transform 0.2s;
  cursor: pointer;
}
.loan-card:hover { box-shadow: var(--shadow-md); transform: translateY(-2px); }
.loan-card-header {
  display: flex;
  align-items: center;
  gap: 0.75rem;
  margin-bottom: 1rem;
}
.loan-card-name { font-size: 0.88rem; font-weight: 500; color: var(--lenme-navy); }
.loan-card-purpose { font-size: 0.75rem; color: #6B7280; }
.loan-card-scores {
  display: flex;
  gap: 0.5rem;
  margin-bottom: 1rem;
}
.loan-card-score {
  flex: 1;
  background: var(--lenme-surface);
